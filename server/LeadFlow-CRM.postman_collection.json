              "raw": "{\n  \"fullName\": \"Jane Smith-Updated\",\n  \"company\": \"Acme Corp International\",\n  \"priority\": \"Medium\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/leads/{{leadId}}",
              "host": ["{{baseUrl}}"],
              "path": ["leads", "{{leadId}}"]
            },
            "description": "Update an existing lead. Only send the fields you want to update."
          },
          "response": [
            {
              "name": "Lead Updated",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Lead updated successfully\",\n  \"data\": {\n    \"_id\": \"...\",\n    \"fullName\": \"Jane Smith-Updated\",\n    \"company\": \"Acme Corp International\",\n    \"priority\": \"Medium\"\n  }\n}"
            }
          ]
        },
