{
  "info": {
    "name": "LeadFlow CRM API",
    "description": "Complete API collection for the LeadFlow CRM application.\n\n## Authentication\n- First, use the **Login** request to authenticate\n- The access token will be automatically set as a Bearer token for all subsequent requests\n- Access tokens expire in 15 minutes. Use **Refresh Token** to get a new one\n\n## Base URL\n`http://localhost:5000/api/v1`\n\n## Variables\n- `baseUrl`: http://localhost:5000/api/v1\n- `accessToken`: Auto-populated after login\n- `leadId`: Set from the Create Lead or List Leads response\n- `noteId`: Set from the Create Note or List Notes response",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "leadflow-crm"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api/v1",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "leadId",
      "value": "",
      "type": "string"
    },
    {
      "key": "noteId",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Health",
      "description": "Server health check and monitoring endpoints",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Returns server status, uptime, memory usage, and environment info."
          },
          "response": [
            {
              "name": "Success Response",
              "status": "OK",
              "code": 200,
              "header": [],
              "body": "{\n  \"success\": true,\n  \"message\": \"Success\",\n  \"data\": {\n    \"status\": \"ok\",\n    \"timestamp\": \"2026-06-16T10:00:00.000Z\",\n    \"uptime\": 123.456,\n    \"environment\": \"development\",\n    \"memoryUsage\": {\n      \"heapUsed\": \"24MB\",\n      \"heapTotal\": \"27MB\"\n    }\n  }\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Authentication",
      "description": "Authentication endpoints for user management and JWT tokens",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('accessToken', jsonData.data.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"StrongP@ss1\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            },
            "description": "Register a new admin user. Password must contain at least one uppercase letter, one lowercase letter, and one number."
          },
          "response": [
            {
              "name": "Registration Success",
              "code": 201,
              "body": "{\n  \"success\": true,\n  \"message\": \"Registration successful\",\n  \"data\": {\n    \"user\": {\n      \"id\": \"...\",\n      \"name\": \"John Doe\",\n      \"email\": \"john@example.com\",\n      \"role\": \"Admin\",\n      \"avatar\": null,\n      \"createdAt\": \"2026-06-16T10:00:00.000Z\"\n    },\n    \"accessToken\": \"eyJhbGci...\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('accessToken', jsonData.data.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@leadflow.com\",\n  \"password\": \"Admin@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Login with email and password. Returns user profile and a JWT access token. Also sets an HttpOnly refresh token cookie."
          },
          "response": [
            {
              "name": "Login Success",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Login successful\",\n  \"data\": {\n    \"user\": {\n      \"id\": \"...\",\n      \"name\": \"Admin User\",\n      \"email\": \"admin@leadflow.com\",\n      \"role\": \"Admin\",\n      \"avatar\": null,\n      \"lastLogin\": \"2026-06-16T10:00:00.000Z\",\n      \"createdAt\": \"2026-06-16T09:00:00.000Z\"\n    },\n    \"accessToken\": \"eyJhbGci...\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            },
            "description": "Get the currently authenticated user's profile. Requires a valid Bearer token in the Authorization header."
          },
          "response": [
            {
              "name": "User Profile",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Success\",\n  \"data\": {\n    \"id\": \"...\",\n    \"name\": \"Admin User\",\n    \"email\": \"admin@leadflow.com\",\n    \"role\": \"Admin\",\n    \"avatar\": null,\n    \"isActive\": true,\n    \"lastLogin\": \"2026-06-16T10:00:00.000Z\",\n    \"createdAt\": \"2026-06-16T09:00:00.000Z\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "refresh"]
            },
            "description": "Refresh the access token using the HttpOnly refresh token cookie set during login. Returns a new access token and sets a new refresh token cookie."
          },
          "response": [
            {
              "name": "Token Refreshed",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Token refreshed successfully\",\n  \"data\": {\n    \"accessToken\": \"eyJhbGci...\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "logout"]
            },
            "description": "Logout the current user. Clears the refresh token from the database and the HttpOnly cookie."
          },
          "response": [
            {
              "name": "Logout Success",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Logout successful\",\n  \"data\": null\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Leads",
      "description": "Lead CRUD operations with search, filter, sort, and pagination",
      "item": [
        {
          "name": "List Leads",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.data.leads && jsonData.data.leads.length > 0) {",
                  "        pm.collectionVariables.set('leadId', jsonData.data.leads[0]._id);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/leads?page=1&limit=10&sort=newest",
              "host": ["{{baseUrl}}"],
              "path": ["leads"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "sort", "value": "newest" },
                { "key": "search", "value": "", "disabled": true },
                { "key": "status", "value": "", "disabled": true },
                { "key": "priority", "value": "", "disabled": true },
                { "key": "leadSource", "value": "", "disabled": true },
                { "key": "startDate", "value": "", "disabled": true },
                { "key": "endDate", "value": "", "disabled": true }
              ]
            },
            "description": "List all leads with pagination, search, filters, and sorting.\n\n**Query Parameters:**\n- `page` (default: 1)\n- `limit` (default: 10, max: 100)\n- `sort` (newest | oldest | name | status | priority)\n- `search` (searches name, email, company, phone)\n- `status` (New | Contacted | Qualified | Proposal Sent | Negotiation | Won | Lost)\n- `priority` (Low | Medium | High)\n- `leadSource` (Website | Referral | LinkedIn | Cold Call | Email | Advertisement | Other)\n- `startDate` / `endDate` (ISO date strings for date range filter)"
          },
          "response": [
            {
              "name": "Leads List",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Success\",\n  \"data\": {\n    \"leads\": [...],\n    \"pagination\": {\n      \"page\": 1,\n      \"limit\": 10,\n      \"total\": 25,\n      \"totalPages\": 3\n    }\n  }\n}"
            }
          ]
        },
        {
          "name": "Create Lead",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('leadId', jsonData.data._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Jane Smith\",\n  \"email\": \"jane.smith@company.com\",\n  \"phone\": \"+1-555-0123\",\n  \"company\": \"Acme Corp\",\n  \"country\": \"United States\",\n  \"leadSource\": \"Website\",\n  \"message\": \"Interested in the enterprise plan with custom integrations.\",\n  \"status\": \"New\",\n  \"priority\": \"High\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/leads",
              "host": ["{{baseUrl}}"],
              "path": ["leads"]
            },
            "description": "Create a new lead. Only `fullName` and `email` are required. All other fields have defaults."
          },
          "response": [
            {
              "name": "Lead Created",
              "code": 201,
              "body": "{\n  \"success\": true,\n  \"message\": \"Lead created successfully\",\n  \"data\": {\n    \"_id\": \"...\",\n    \"fullName\": \"Jane Smith\",\n    \"email\": \"jane.smith@company.com\",\n    \"phone\": \"+1-555-0123\",\n    \"company\": \"Acme Corp\",\n    \"country\": \"United States\",\n    \"leadSource\": \"Website\",\n    \"message\": \"Interested in the enterprise plan with custom integrations.\",\n    \"status\": \"New\",\n    \"priority\": \"High\",\n    \"assignedTo\": null,\n    \"notesCount\": 0,\n    \"createdBy\": \"...\",\n    \"createdAt\": \"2026-06-16T10:00:00.000Z\",\n    \"updatedAt\": \"2026-06-16T10:00:00.000Z\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Get Lead",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/leads/{{leadId}}",
              "host": ["{{baseUrl}}"],
              "path": ["leads", "{{leadId}}"]
            },
            "description": "Get a single lead by ID. Includes populated notes if available."
          },
          "response": [
            {
              "name": "Lead Details",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Success\",\n  \"data\": {\n    \"_id\": \"...\",\n    \"fullName\": \"Jane Smith\",\n    \"email\": \"jane.smith@company.com\",\n    \"status\": \"New\",\n    \"priority\": \"High\",\n    \"notes\": []\n  }\n}"
            }
          ]
        },
