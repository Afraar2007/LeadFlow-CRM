              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"Contacted\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/leads/{{leadId}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["leads", "{{leadId}}", "status"]
            },
            "description": "Quickly update the status of a lead. Valid statuses: New, Contacted, Qualified, Proposal Sent, Negotiation, Won, Lost."
          },
          "response": [
            {
              "name": "Status Updated",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Lead status updated successfully\",\n  \"data\": {\n    \"_id\": \"...\",\n    \"status\": \"Contacted\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Delete Lead",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/leads/{{leadId}}",
              "host": ["{{baseUrl}}"],
              "path": ["leads", "{{leadId}}"]
            },
            "description": "Delete a lead permanently. This will also delete all associated notes."
          },
          "response": [
            {
              "name": "Lead Deleted",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Lead deleted successfully\",\n  \"data\": null\n}"
            }
          ]
        }
      ]
    },
    {
